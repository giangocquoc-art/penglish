# Frontend-safe Supabase variables. These may be exposed to Vite client code.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local CLI deployment only. Do not expose service-role secrets to frontend code.
SUPABASE_PROJECT_REF=your-project-ref

# Optional for Supabase CLI auth on local machines/CI. Keep out of Git.
# SUPABASE_ACCESS_TOKEN=your-local-supabase-access-token

# Existing local API/Express deployment variables may still be needed while the
# project remains Vite + Express + SQLite and is not fully Supabase-backed.
# VITE_API_URL=http://localhost:8080
# JWT_SECRET=change-me-for-server-only
